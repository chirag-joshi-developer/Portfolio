SECRET_KEY=change-me-in-production
# Copy this file to `.env` for changes to take effect. `.env.example` is not loaded.
# Use 1 for Django debug pages, 0 for production-like mode.
DEBUG=0
# Set to 1 only on a real production host behind TLS (enables HSTS + SSL redirect).
IS_PRODUCTION=0

# Comma-separated lists — update these to your real domain before deploying.
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

MYSQL_DATABASE=portfolio
MYSQL_USER=portfolio_user
MYSQL_PASSWORD=portfolio_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql://portfolio_user:portfolio_password@mysql:3306/portfolio

DJANGO_SUPERUSER_USERNAME=chirag
DJANGO_SUPERUSER_EMAIL=chirag@example.com
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!

# Leave empty for same-origin /api via Vite or nginx proxy. Set only if API is on another host.
VITE_API_URL=
