# HTTP-only IP deploy template. Copy to `.env.production` and replace YOUR_SERVER_IP.
#   copy .env.production.example .env.production
#
# Start:
#   docker compose --env-file .env.production -f docker-compose.prod.yml up --build -d

SECRET_KEY=change-me-in-production
DEBUG=0
# Must stay 0 for plain HTTP. Set to 1 only after HTTPS works.
IS_PRODUCTION=0

ALLOWED_HOSTS=YOUR_SERVER_IP,backend
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP
CSRF_TRUSTED_ORIGINS=http://YOUR_SERVER_IP
FRONTEND_URL=http://YOUR_SERVER_IP

MYSQL_DATABASE=portfolio
MYSQL_USER=portfolio_user
MYSQL_PASSWORD=portfolio_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql://portfolio_user:portfolio_password@mysql:3306/portfolio

DJANGO_SUPERUSER_USERNAME=chirag
DJANGO_SUPERUSER_EMAIL=chirag@example.com
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!

VITE_API_URL=

NGINX_HTTP_PORT=80
