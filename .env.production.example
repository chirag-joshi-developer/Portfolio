# Cloudflare Flexible SSL + domain template.
# Copy to `.env.production` and replace YOUR_DOMAIN (and IP if different).
#
# Start on the server:
#   docker compose --env-file .env.production -f docker-compose.prod.yml up --build -d
#
# Keep IS_PRODUCTION=0 on Flexible SSL (Cloudflare→origin is HTTP).
# After Full (strict) + origin TLS, you can set IS_PRODUCTION=1.

SECRET_KEY=change-me-in-production
DEBUG=0
IS_PRODUCTION=0

ALLOWED_HOSTS=YOUR_DOMAIN,www.YOUR_DOMAIN,129.121.117.172,backend
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN,http://YOUR_DOMAIN,http://www.YOUR_DOMAIN,http://129.121.117.172
CSRF_TRUSTED_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN,http://YOUR_DOMAIN,http://www.YOUR_DOMAIN,http://129.121.117.172
FRONTEND_URL=https://YOUR_DOMAIN

MYSQL_DATABASE=portfolio
MYSQL_USER=portfolio_user
MYSQL_PASSWORD=portfolio_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql://portfolio_user:portfolio_password@mysql:3306/portfolio

DJANGO_SUPERUSER_USERNAME=chirag
DJANGO_SUPERUSER_EMAIL=chirag@example.com
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!

VITE_API_URL=

NGINX_HTTP_PORT=80
